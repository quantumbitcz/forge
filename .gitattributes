# Shell scripts must use LF — CRLF breaks shebangs and hooks fail silently
*.sh text eol=lf

# Markdown and config files — normalize to LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Test files must use LF — BATS harness is sensitive to line endings
*.bats text eol=lf
