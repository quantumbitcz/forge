{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge Configuration Schema",
  "description": "Validates forge.local.md and forge-config.md YAML frontmatter",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "object",
      "required": ["language", "framework", "testing"],
      "properties": {
        "language": {
          "type": ["string", "null"],
          "enum": ["kotlin", "java", "typescript", "python", "go", "rust", "swift", "c", "csharp", "ruby", "php", "dart", "elixir", "scala", "cpp", null]
        },
        "framework": {
          "type": ["string", "null"],
          "enum": ["spring", "react", "fastapi", "axum", "swiftui", "vapor", "express", "sveltekit", "k8s", "embedded", "go-stdlib", "aspnet", "django", "nextjs", "gin", "jetpack-compose", "kotlin-multiplatform", "angular", "nestjs", "vue", "svelte", null]
        },
        "variant": { "type": ["string", "null"] },
        "testing": {
          "type": ["string", "null"],
          "enum": ["kotest", "junit5", "vitest", "jest", "pytest", "go-testing", "xctest", "rust-test", "xunit-nunit", "testcontainers", "playwright", "cypress", "cucumber", "k6", "detox", "rspec", "phpunit", "exunit", "scalatest", null]
        },
        "web": { "type": ["string", "null"] },
        "persistence": { "type": ["string", "null"] },
        "database": { "type": ["string", "null"] },
        "migrations": { "type": ["string", "null"] },
        "api_protocol": { "type": ["string", "null"] },
        "messaging": { "type": ["string", "null"] },
        "caching": { "type": ["string", "null"] },
        "search": { "type": ["string", "null"] },
        "storage": { "type": ["string", "null"] },
        "auth": { "type": ["string", "null"] },
        "observability": { "type": ["string", "null"] },
        "build_system": { "type": ["string", "null"] },
        "ci": { "type": ["string", "null"] },
        "container": { "type": ["string", "null"] },
        "orchestrator": { "type": ["string", "null"] },
        "code_quality": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            { "type": "array", "items": { "type": "object" } },
            { "type": "null" }
          ]
        }
      }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "critical_weight": { "type": "number", "minimum": 10 },
        "warning_weight": { "type": "number", "minimum": 1 },
        "info_weight": { "type": "number", "minimum": 0 },
        "pass_threshold": { "type": "number", "minimum": 60, "maximum": 100 },
        "concerns_threshold": { "type": "number", "minimum": 40 },
        "oscillation_tolerance": { "type": "number", "minimum": 0, "maximum": 20 }
      }
    },
    "convergence": {
      "type": "object",
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 3, "maximum": 20 },
        "plateau_threshold": { "type": "integer", "minimum": 0, "maximum": 10 },
        "plateau_patience": { "type": "integer", "minimum": 1, "maximum": 5 },
        "target_score": { "type": "number", "minimum": 60, "maximum": 100 },
        "safety_gate": { "type": "boolean" }
      }
    },
    "shipping": {
      "type": "object",
      "properties": {
        "min_score": { "type": "number", "minimum": 60, "maximum": 100 },
        "evidence_max_age_minutes": { "type": "integer", "minimum": 5, "maximum": 60 }
      }
    },
    "total_retries_max": { "type": "integer", "minimum": 5, "maximum": 30 },
    "autonomous": { "type": "boolean" },
    "caveman": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "default_mode": { "enum": ["lite", "full", "ultra"], "default": "lite" },
        "output_mode": { "enum": ["off", "lite", "full", "ultra"] },
        "auto_clarity": { "type": "boolean" },
        "input_compression": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auto_compress_on_init": { "type": "boolean" },
            "backup_suffix": { "type": "string", "pattern": "^\\." }
          }
        }
      }
    },
    "token_pricing": {
      "type": "object",
      "description": "Token pricing overrides (per million tokens). Falls back to built-in defaults.",
      "properties": {
        "opus_input": { "type": "number", "minimum": 0 },
        "opus_output": { "type": "number", "minimum": 0 },
        "sonnet_input": { "type": "number", "minimum": 0 },
        "sonnet_output": { "type": "number", "minimum": 0 },
        "haiku_input": { "type": "number", "minimum": 0 },
        "haiku_output": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "compression_eval": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable compression evaluation tracking"
        },
        "auto_run_after_compress": {
          "type": "boolean",
          "default": false,
          "description": "Run validation automatically after /forge-compress"
        },
        "drift_threshold_pct": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200,
          "default": 50,
          "description": "Percentage over expected range to flag as drift"
        }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "description": "Per-agent configuration for conditional Phase 07 agents (fg-143, fg-155, fg-414, fg-506, fg-555).",
      "properties": {
        "i18n_validator": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true, "description": "Run fg-155-i18n-validator at PREFLIGHT (cheap regex scan)." },
            "max_findings_per_run": { "type": "integer", "minimum": 1, "default": 200, "description": "Truncation cap; emits one INFO I18N-TRUNCATED if exceeded." }
          },
          "additionalProperties": false
        },
        "observability_bootstrap": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false, "description": "Run fg-143-observability-bootstrap at PREFLIGHT; opt-in because it writes stubs into .forge/worktree/." }
          },
          "additionalProperties": false
        },
        "migration_verifier": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true, "description": "Run fg-506-migration-verifier during VERIFYING; auto-skips outside migration mode." }
          },
          "additionalProperties": false
        },
        "resilience_testing": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false, "description": "Run fg-555-resilience-tester during VERIFYING; opt-in (chaos + flake risk)." },
            "max_duration_s": { "type": "integer", "minimum": 1, "default": 120, "description": "Budget clamp for the resilience probe run." },
            "chaos_enabled": { "type": "boolean", "default": false, "description": "Second opt-in for dynamic chaos probes (findings capped at WARNING)." }
          },
          "additionalProperties": false
        },
        "license_reviewer": {
          "type": "object",
          "description": "License compliance reviewer (fg-414-license-reviewer).",
          "properties": {
            "policy_file": {
              "type": ["string", "null"],
              "default": ".forge/license-policy.json",
              "description": "Path to an optional JSON policy file (allow/warn/deny lists)."
            },
            "fail_open_when_missing": {
              "type": "boolean",
              "default": true,
              "description": "When true, LICENSE-* findings cap at WARNING when the policy file is absent or unreadable. When false, missing policy emits CRITICAL LICENSE-POLICY-VIOLATION."
            },
            "embedded_defaults": {
              "type": "object",
              "description": "Used iff policy_file is absent.",
              "properties": {
                "allow": { "type": "array", "items": { "type": "string" }, "default": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC", "Unlicense", "CC0-1.0"] },
                "warn":  { "type": "array", "items": { "type": "string" }, "default": ["LGPL-2.1+", "LGPL-3.0+", "MPL-2.0"] },
                "deny":  { "type": "array", "items": { "type": "string" }, "default": ["AGPL-*", "SSPL-*", "Commons-Clause", "BUSL-*"] }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
