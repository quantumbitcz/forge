{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Corpus entry structural",
  "type": "object",
  "required": ["name", "files"],
  "properties": {
    "name": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"},
    "files": {
      "type": "array",
      "allOf": [
        {"contains": {"const": "requirement.md"}},
        {"contains": {"const": "acceptance-criteria.yaml"}},
        {"contains": {"const": "seed-project.tar.gz"}},
        {"contains": {"const": "expected-deliverables.yaml"}},
        {"contains": {"const": "metadata.yaml"}}
      ]
    }
  }
}
