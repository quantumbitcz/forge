{
  "_note": "Cloud credential detection patterns for L1 security checks. Each pattern is a regex applied to file content. Called by the check engine as part of the SEC-SECRET detection pipeline.",
  "schema_version": "1.0.0",
  "patterns": [
    {
      "id": "SEC-SECRET-AWS-KEY",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "CRITICAL",
      "description": "AWS Access Key ID",
      "provider": "aws"
    },
    {
      "id": "SEC-SECRET-AWS-SECRET",
      "pattern": "(?i)(?:aws_secret_access_key|aws_secret|secret_access_key)\\s*[:=]\\s*['\"]?[0-9a-zA-Z/+=]{40}",
      "severity": "CRITICAL",
      "description": "AWS Secret Access Key",
      "provider": "aws"
    },
    {
      "id": "SEC-SECRET-GCP-SERVICE-ACCOUNT",
      "pattern": "\"type\"\\s*:\\s*\"service_account\"",
      "severity": "CRITICAL",
      "description": "GCP Service Account JSON key file",
      "provider": "gcp"
    },
    {
      "id": "SEC-SECRET-GCP-API-KEY",
      "pattern": "AIza[0-9A-Za-z_-]{35}",
      "severity": "CRITICAL",
      "description": "GCP API Key",
      "provider": "gcp"
    },
    {
      "id": "SEC-SECRET-AZURE-CONNECTION",
      "pattern": "DefaultEndpointsProtocol=https;AccountName=[^;]+;AccountKey=[^;]+",
      "severity": "CRITICAL",
      "description": "Azure Storage Connection String",
      "provider": "azure"
    },
    {
      "id": "SEC-SECRET-AZURE-SAS",
      "pattern": "(?i)(?:sv=\\d{4}-\\d{2}-\\d{2}&)(?:[a-z]{2}=[^&]+&){2,}sig=[A-Za-z0-9%+/=]+",
      "severity": "CRITICAL",
      "description": "Azure SAS Token",
      "provider": "azure"
    },
    {
      "id": "SEC-SECRET-GITHUB-PAT",
      "pattern": "gh[ps]_[A-Za-z0-9_]{36,}",
      "severity": "CRITICAL",
      "description": "GitHub Personal Access Token or Fine-Grained Token",
      "provider": "github"
    },
    {
      "id": "SEC-SECRET-GITHUB-FINE-GRAINED",
      "pattern": "github_pat_[A-Za-z0-9_]{22,}",
      "severity": "CRITICAL",
      "description": "GitHub Fine-Grained Personal Access Token",
      "provider": "github"
    },
    {
      "id": "SEC-SECRET-SLACK-TOKEN",
      "pattern": "xox[bpras]-[0-9a-zA-Z-]{10,}",
      "severity": "CRITICAL",
      "description": "Slack Bot, User, or App Token",
      "provider": "slack"
    },
    {
      "id": "SEC-SECRET-SLACK-WEBHOOK",
      "pattern": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[a-zA-Z0-9]+",
      "severity": "CRITICAL",
      "description": "Slack Incoming Webhook URL",
      "provider": "slack"
    },
    {
      "id": "SEC-SECRET-STRIPE-LIVE",
      "pattern": "sk_live_[0-9a-zA-Z]{24,}",
      "severity": "CRITICAL",
      "description": "Stripe Live Secret Key",
      "provider": "stripe"
    },
    {
      "id": "SEC-SECRET-STRIPE-TEST",
      "pattern": "sk_test_[0-9a-zA-Z]{24,}",
      "severity": "WARNING",
      "description": "Stripe Test Secret Key",
      "provider": "stripe"
    },
    {
      "id": "SEC-SECRET-JWT",
      "pattern": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
      "severity": "CRITICAL",
      "description": "JSON Web Token (JWT)",
      "provider": "generic"
    },
    {
      "id": "SEC-SECRET-BEARER",
      "pattern": "(?i)(?:Authorization|Bearer)\\s*[:=]?\\s*['\"]?Bearer\\s+[A-Za-z0-9._~+/=-]{20,}",
      "severity": "CRITICAL",
      "description": "Bearer Token in Authorization Header",
      "provider": "generic"
    },
    {
      "id": "SEC-SECRET-PRIVATE-KEY-RSA",
      "pattern": "-----BEGIN (?:RSA )?PRIVATE KEY-----",
      "severity": "CRITICAL",
      "description": "RSA Private Key Header",
      "provider": "generic"
    },
    {
      "id": "SEC-SECRET-PRIVATE-KEY-EC",
      "pattern": "-----BEGIN EC PRIVATE KEY-----",
      "severity": "CRITICAL",
      "description": "EC Private Key Header",
      "provider": "generic"
    },
    {
      "id": "SEC-SECRET-PRIVATE-KEY-ED25519",
      "pattern": "-----BEGIN (?:OPENSSH |Ed25519 )?PRIVATE KEY-----",
      "severity": "CRITICAL",
      "description": "Ed25519 / OpenSSH Private Key Header",
      "provider": "generic"
    },
    {
      "id": "SEC-SECRET-PRIVATE-KEY-ENCRYPTED",
      "pattern": "-----BEGIN ENCRYPTED PRIVATE KEY-----",
      "severity": "CRITICAL",
      "description": "Encrypted Private Key Header",
      "provider": "generic"
    }
  ]
}
