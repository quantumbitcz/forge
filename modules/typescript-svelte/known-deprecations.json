{
  "version": 2,
  "deprecations": [
    {
      "pattern": "export\\s+let\\s+\\w+.*(?:PageData|LayoutData|PageServerData)",
      "replacement": "Use the `$props()` rune to receive page/layout data instead of `export let` declarations",
      "package": "svelte",
      "since": "Svelte 5",
      "removed_in": null,
      "applies_from": "Svelte 5",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    },
    {
      "pattern": "\\$:\\s+",
      "replacement": "Use `$derived()` for reactive derivations or `$effect()` for side effects instead of `$:` reactive statements",
      "package": "svelte",
      "since": "Svelte 5",
      "removed_in": null,
      "applies_from": "Svelte 5",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    },
    {
      "pattern": "(?:onMount|onDestroy)\\s*\\(",
      "replacement": "Use `$effect()` with an optional cleanup return function instead of `onMount`/`onDestroy` lifecycle hooks",
      "package": "svelte",
      "since": "Svelte 5",
      "removed_in": null,
      "applies_from": "Svelte 5",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    },
    {
      "pattern": "<svelte:component\\s+this\\s*=",
      "replacement": "Use dynamic `{@render ...}` blocks or snippets instead of `<svelte:component this={...}>`",
      "package": "svelte",
      "since": "Svelte 5",
      "removed_in": null,
      "applies_from": "Svelte 5",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    },
    {
      "pattern": "createEventDispatcher\\s*\\(",
      "replacement": "Use callback props instead of `createEventDispatcher()`. Pass event handlers as props directly",
      "package": "svelte",
      "since": "Svelte 5",
      "removed_in": null,
      "applies_from": "Svelte 5",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    },
    {
      "pattern": "(?:beforeNavigate|afterNavigate)\\s*\\(",
      "replacement": "Use the `onNavigate` and `beforeNavigate`/`afterNavigate` hooks from `$app/navigation` with the updated SvelteKit 2 signatures",
      "package": "@sveltejs/kit",
      "since": "SvelteKit 2",
      "removed_in": null,
      "applies_from": "SvelteKit 2",
      "applies_to": "*",
      "added": "2026-03-22",
      "addedBy": "seed"
    }
  ]
}
