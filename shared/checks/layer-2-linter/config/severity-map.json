{
  "_match_order": "exact rule ID first, then longest glob prefix wins",
  "detekt": {
    "SwallowedException": "CRITICAL",
    "TooGenericExceptionCaught": "WARNING",
    "complexity.*": "WARNING",
    "coroutines.*": "WARNING",
    "exceptions.*": "WARNING",
    "performance.*": "WARNING",
    "style.*": "INFO"
  },
  "eslint": {
    "no-eval": "CRITICAL",
    "react-hooks/exhaustive-deps": "WARNING",
    "@typescript-eslint/no-explicit-any": "WARNING",
    "_severity_map": {
      "error": "WARNING",
      "warn": "INFO"
    }
  },
  "clippy": {
    "correctness": "CRITICAL",
    "suspicious": "WARNING",
    "perf": "WARNING",
    "style": "INFO",
    "nursery": "INFO"
  },
  "ruff": {
    "S*": "WARNING",
    "E*": "INFO",
    "F*": "WARNING",
    "UP*": "INFO",
    "ASYNC*": "WARNING",
    "B*": "WARNING"
  },
  "staticcheck": {
    "SA*": "WARNING",
    "S*": "WARNING",
    "ST*": "INFO",
    "QF*": "INFO"
  },
  "swiftlint": {
    "error": "WARNING",
    "warning": "INFO"
  },
  "checkstyle": {
    "ERROR": "WARNING",
    "WARNING": "INFO"
  },
  "clang-tidy": {
    "error": "WARNING",
    "warning": "INFO",
    "modernize-*": "INFO",
    "bugprone-*": "WARNING",
    "cert-*": "WARNING",
    "security-*": "CRITICAL"
  },
  "dotnet-format": {
    "error": "WARNING",
    "warning": "INFO",
    "info": "INFO",
    "hidden": "INFO"
  },
  "golangci-lint": {
    "error": "WARNING",
    "warning": "INFO"
  },
  "android-lint": {
    "Fatal": "CRITICAL",
    "Error": "WARNING",
    "Warning": "INFO",
    "Information": "INFO"
  },
  "credo": {
    "consistency": "INFO",
    "design": "WARNING",
    "readability": "INFO",
    "refactor": "WARNING",
    "warning": "WARNING"
  },
  "dart-analyzer": {
    "error": "WARNING",
    "warning": "INFO",
    "info": "INFO",
    "lint": "INFO"
  },
  "go-vet": {
    "_severity_map": {
      "error": "WARNING"
    }
  },
  "phpstan": {
    "_severity_map": {
      "error": "WARNING"
    }
  },
  "rubocop": {
    "Fatal": "CRITICAL",
    "Error": "WARNING",
    "Warning": "INFO",
    "Convention": "INFO",
    "Refactor": "INFO"
  },
  "scalafmt": {
    "_severity_map": {
      "error": "WARNING"
    }
  },
  "biome": {
    "error": "WARNING",
    "warning": "INFO",
    "nursery.*": "INFO",
    "correctness.*": "WARNING",
    "suspicious.*": "WARNING",
    "security.*": "CRITICAL"
  },
  "cppcheck": {
    "error": "WARNING",
    "warning": "INFO",
    "style": "INFO",
    "performance": "INFO",
    "portability": "INFO"
  },
  "ktlint": {
    "_severity_map": {
      "error": "WARNING"
    }
  },
  "phpcs": {
    "ERROR": "WARNING",
    "WARNING": "INFO"
  },
  "pylint": {
    "fatal": "CRITICAL",
    "error": "WARNING",
    "warning": "INFO",
    "convention": "INFO",
    "refactor": "INFO"
  },
  "scalafix": {
    "_severity_map": {
      "error": "WARNING"
    }
  },
  "spotbugs": {
    "1": "CRITICAL",
    "2": "WARNING",
    "3": "INFO"
  },
  "standardrb": {
    "Error": "WARNING",
    "Convention": "INFO",
    "Refactor": "INFO"
  }
}
