{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/shared/checks/engine.sh --hook",
          "timeout": 5000
        }
      ]
    },
    {
      "event": "PostToolUse",
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pipeline-checkpoint.sh",
          "timeout": 5000
        }
      ]
    },
    {
      "event": "Stop",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/hooks/feedback-capture.sh",
          "timeout": 3000
        }
      ]
    }
  ]
}
