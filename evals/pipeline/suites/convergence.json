{
  "name": "convergence",
  "version": "1.0.0",
  "description": "10-task convergence speed measurement suite",
  "default_timeout_minutes": 45,
  "default_model": "sonnet",
  "tasks": [
    {
      "id": "cv-01-single-fix",
      "language": "python",
      "difficulty": "easy",
      "description": "KeyError from case-sensitive email lookup. Single-file fix measuring baseline convergence speed.",
      "fixture": "python/py-01-dict-keyerror",
      "validation_command": "python3 -m pytest tests/ -v",
      "tags": ["convergence", "single-file"],
      "expected_convergence": {
        "max_iterations": 3,
        "expected_phase_1_iterations": 1,
        "expected_phase_2_iterations": 1,
        "should_not_plateau": true,
        "should_not_regress": true,
        "max_safety_gate_restarts": 0
      }
    },
    {
      "id": "cv-02-type-fix",
      "language": "python",
      "difficulty": "medium",
      "description": "Circular import causing AttributeError. Multi-file fix requiring dependency restructuring.",
      "fixture": "python/py-04-import-cyc",
      "validation_command": "python3 -m pytest tests/ -v",
      "tags": ["convergence", "multi-file"],
      "expected_convergence": {
        "max_iterations": 5,
        "expected_phase_1_iterations": 2,
        "expected_phase_2_iterations": 2,
        "should_not_plateau": true,
        "should_not_regress": true,
        "max_safety_gate_restarts": 1
      }
    },
    {
      "id": "cv-03-null-fix",
